<script>
var A = {};
var step = 0;
var SL = ['','Composición','Reacción','Preocupación','Moneda','Conocimiento','Frecuencia','Capital $'];

// ── SLIDERS TRAMOS ──
var tramoVals = [33, 33, 34];
var tramoColors = ['var(--green)', 'var(--teal)', 'var(--gold)'];

function updTramo(idx, val) {
  val = parseInt(val);
  tramoVals[idx] = val;
  // Autoajustar los otros dos proporcionalmente
  const rest = 100 - val;
  const others = [0,1,2].filter(i=>i!==idx);
  const sumOthers = tramoVals[others[0]] + tramoVals[others[1]];
  if (sumOthers > 0) {
    tramoVals[others[0]] = Math.round(rest * tramoVals[others[0]] / sumOthers);
    tramoVals[others[1]] = rest - tramoVals[others[0]];
  } else {
    tramoVals[others[0]] = Math.floor(rest / 2);
    tramoVals[others[1]] = rest - tramoVals[others[0]];
  }
  tramoVals[idx] = val;
  // Update UI
  [0,1,2].forEach(i => {
    const v = tramoVals[i];
    document.getElementById(`pct${i}`).textContent = v + '%';
    const sl = document.getElementById(`sl${i}`);
    sl.value = v;
    sl.style.setProperty('--p', v + '%');
  });
  updateTotal();
  // Guardar en A
  A.liquid = tramoVals[0];
  A.corto  = tramoVals[1];
  A.largo  = tramoVals[2];
}

function updateTotal() {
  const tot = tramoVals.reduce((a,b)=>a+b,0);
  const el = document.getElementById('totalVal');
  const hint = document.getElementById('totalHint');
  el.textContent = tot + '%';
  if (tot === 100) {
    el.className = 'total-val ok';
    hint.textContent = '✓ Perfecto — podés continuar';
  } else if (tot < 100) {
    el.className = 'total-val bad';
    hint.textContent = `Falta asignar ${100-tot}%`;
  } else {
    el.className = 'total-val bad';
    hint.textContent = `Excedés por ${tot-100}%`;
  }
}

// Init tramos
A.liquid=33; A.corto=33; A.largo=34;
updateTotal();

// ── SOFISTICACIÓN ──
function pickFrecuencia(card, val) {
  card.closest('.opts').querySelectorAll('.opt').forEach(o=>o.classList.remove('sel'));
  card.classList.add('sel');
  A.frecuencia = val;
  checkSofis();
}

function checkSofis() {
  if (!A.conocimiento || !A.frecuencia) return;
  // Calcular nivel
  const kMap = {basico:1, intermedio:2, avanzado:3};
  const fMap = {nunca:1, mensual:2, semanal:3};
  const score = kMap[A.conocimiento] + fMap[A.frecuencia]; // 2-6
  let nivel, icono, desc;
  if (score <= 3) { nivel='Básico-Pasivo'; icono='🌱'; desc='Instrumentos simples y de bajo mantenimiento. Sin renta variable activa.'; A.sofis='bajo'; }
  else if (score <= 4) { nivel='Intermedio'; icono='📚'; desc='Podés manejar acciones, CEDEARs y bonos con seguimiento mensual.'; A.sofis='medio'; }
  else { nivel='Avanzado-Activo'; icono='🎯'; desc='Acceso a carry trade, soberanos con plazo corto y estrategias dinámicas.'; A.sofis='alto'; }
  A.nivelSofis = nivel;
  document.getElementById('sofisNivel').textContent = 'Perfil técnico: ' + nivel;
  document.getElementById('sofisDesc').textContent = desc;
  document.getElementById('sofisIcon').textContent = icono;
  document.getElementById('sofisResult').classList.add('show');
  document.getElementById('n6').disabled = false;
}

// ── PROGRESS ──
function rProg() {
  const el = document.getElementById('PT');
  el.innerHTML = '';
  for (let i=1; i<=7; i++) {
    const w = document.createElement('div'); w.className='pstep';
    const d = document.createElement('div');
    d.className = 'pdot' + (step===i?' active':'') + (step>i?' done':'');
    if (step<=i) { const n=document.createElement('span'); n.className='pn'; n.textContent=i; d.appendChild(n); }
    const l = document.createElement('span'); l.className='plbl'; l.textContent=SL[i]; d.appendChild(l);
    w.appendChild(d);
    if (i<7) { const ln=document.createElement('div'); ln.className='pline'+(step>i?' done':''); w.appendChild(ln); }
    el.appendChild(w);
  }
}

function go(n) {
  step = (n==='result') ? 9 : n;
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(n==='result'?'sR':`s${n}`).classList.add('active');
  rProg();
  window.scrollTo({top:0,behavior:'smooth'});
}

function pick(card, key, val) {
  card.closest('.opts').querySelectorAll('.opt').forEach(o=>o.classList.remove('sel'));
  card.classList.add('sel');
  A[key] = val;
  const b = document.getElementById(`n${step}`);
  if (b) b.disabled = false;
}

// ── CAPITAL ──
var CAPS=[{a:'100.000',u:100},{a:'200.000',u:200},{a:'300.000',u:300},{a:'500.000',u:500},{a:'750.000',u:750},{a:'1.000.000',u:1000},{a:'1.500.000',u:1500},{a:'2.000.000',u:2000},{a:'3.000.000',u:3000},{a:'5.000.000',u:5000},{a:'7.000.000',u:7000},{a:'10.000.000',u:10000},{a:'20.000.000',u:20000},{a:'50.000.000+',u:50000}];
function updCap(v) {
  const s=CAPS[Math.round(v/100*(CAPS.length-1))];
  document.getElementById('CD').textContent=s.a;
  document.getElementById('CU').textContent='≈ USD '+s.u.toLocaleString();
  document.getElementById('CR').style.setProperty('--pct',v+'%');
  A.cARS=s.a; A.cUSD=s.u;
  document.querySelectorAll('.qbtn').forEach(b=>b.classList.remove('active'));
}
function setCap(v,ars,usd,btn){
  document.getElementById('CR').value=v;
  document.getElementById('CD').textContent=ars;
  document.getElementById('CU').textContent='≈ USD '+usd.toLocaleString();
  document.getElementById('CR').style.setProperty('--pct',v+'%');
  A.cARS=ars; A.cUSD=usd;
  document.querySelectorAll('.qbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}
A.cARS='500.000'; A.cUSD=500;

// ── INSTRUMENTOS ──
const COL={cer:'#186e37',lecaps:'#126973',fci_mm:'#1a3a6a',fci_infl:'#2e6b9e',acciones:'#b9261a',cedears:'#6b3fa0',on:'#a55500',fci_usd:'#7a4000',soberanos:'#0f2348'};
const ICO={cer:'🔐',lecaps:'⚡',fci_mm:'💧',fci_infl:'🔥',acciones:'📊',cedears:'🌐',on:'🏢',fci_usd:'💵',soberanos:'🇦🇷'};
const NOM={cer:'Bonos CER / FCI',lecaps:'LECAPs / FCI',fci_mm:'FCI Money Market',fci_infl:'FCI Institu (Inflación Linked)',acciones:'Acciones ARG',cedears:'CEDEARs',on:'Oblig. Negociables / FCI USD',fci_usd:'FCI USD',soberanos:'Bonos Soberanos USD'};
const WHY={
  cer:'Bonos que ajustan por CER o FCI con cartera inflation-linked. Protegen el poder adquisitivo en pesos.',
  lecaps:'LECAPs / BONCAPs o FCI de tasa fija en pesos. Rendimiento predecible con alta liquidez para plazos cortos.',
  fci_mm:'Alta liquidez inmediata. Ideal para el tramo líquido.',
  fci_infl:'FCI con cartera de activos CER e inflation-linked. Cobertura adicional ante inflación con gestión profesional.',
  acciones:'Renta variable local. Mayor potencial en ciclos alcistas del Merval.',
  cedears:'Acciones globales operadas en ARS. Cobertura cambiaria implícita.',
  on:'Oblig. Negociables o FCI en USD. Cobertura cambiaria total con renta en dólares de emisores privados.',
  fci_usd:'FCI en dólares. Diversificación y liquidez en USD con gestión profesional.',
  soberanos:'Alta beta al riesgo argentino. Potencial ante mejora del crédito soberano. Requiere seguimiento activo.',
};

// ── LÓGICA DE PONDERACIÓN ──
function build() {
  const {reaccion, preocupa, moneda, sofis} = A;
  const frecuencia = A.frecuencia || 'semanal';
  const bajFrecuencia = (frecuencia === 'nunca' || frecuencia === 'mensual');
  const usd   = A.cUSD;
  const liq   = A.liquid || 0;
  const corto = A.corto  || 0;
  const largo = A.largo  || 0;

  // ── REGLAS DE EXCLUSIÓN ──
  const rvOK    = reaccion !== 'retiro' && A.conocimiento !== 'basico';  // básico: sin renta variable
  const accOK   = rvOK && !bajFrecuencia;  // acciones solo con revisión frecuente
  const onOK    = (moneda === 'dolares' || moneda === 'mixto') && largo > 30 && usd >= 10000 && preocupa !== 'inflacion';
  const sbOK    = reaccion !== 'retiro' && (sofis === 'alto' || sofis === 'medio') && preocupa !== 'inflacion' && (sofis === 'alto' || largo > 20);
  const carryOK = sofis === 'alto' && reaccion === 'compro' && largo > 5;

  let w = {cer:0, lecaps:0, fci_mm:0, fci_infl:0, acciones:0, cedears:0, on:0, fci_usd:0, soberanos:0};

  // ── LÍQUIDO → siempre FCI + LECAPs, independiente de todo ──
  w.fci_mm += liq * 1.0;

  // ── CORTO PLAZO → LECAPs + CER (renta fija de corto) ──
  // Si preocupa cambio/dólares: más LECAPs que CER
  if (preocupa === 'inflacion') {
    w.cer    += corto * 0.6;
    w.lecaps += corto * 0.4;
  } else if (preocupa === 'cambio') {
    w.lecaps += corto * 0.7;
    w.cer    += corto * 0.3;
  } else {
    w.lecaps += corto * 0.55;
    w.cer    += corto * 0.45;
  }

  // ── LARGO PLAZO → según reacción Y preocupación ──
  // ── REGLA USD: preocupa dólar O valúa en dólares → 100% en ON / FCI USD ──
  const dolarLP = (preocupa === 'cambio' || moneda === 'dolares');
  if (largo > 0) {
    if (dolarLP) {
      w.on      += largo * 0.60;
      w.fci_usd += largo * 0.40;
    } else if (reaccion === 'retiro') {
      // Conservador: renta fija — pero respeta preocupación
      if (preocupa === 'inflacion') {
        w.cer      += largo * 0.60;
        w.lecaps   += largo * 0.20;
        w.fci_infl += largo * 0.20;
      } else if (preocupa === 'cambio' || (preocupa === 'ambas' && (moneda === 'dolares' || moneda === 'mixto'))) {
        w.on     += largo * 0.50;
        w.fci_mm += largo * 0.25;
        w.lecaps += largo * 0.15;
        w.cer    += largo * 0.10;
      } else {
        w.cer    += largo * 0.45;
        w.lecaps += largo * 0.35;
        w.on     += largo * 0.10;
        w.fci_mm += largo * 0.10;
      }
    } else if (!dolarLP && reaccion === 'espero') {
      // Moderado
      if (bajFrecuencia) {
        // Revisión mensual/rara: sin acciones, CEDEARs solo 15%, prioridad ONs + FCI
        if (preocupa === 'inflacion') {
          w.cer      += largo * 0.50;
          w.lecaps   += largo * 0.25;
          w.fci_infl += largo * 0.25;
        } else if (preocupa === 'cambio') {
          w.on     += largo * 0.40;
          w.fci_mm += largo * 0.30;
          w.cedears+= largo * 0.15;
          w.cer    += largo * 0.15;
        } else {
          w.on     += largo * 0.35;
          w.fci_mm += largo * 0.25;
          w.cer    += largo * 0.25;
          w.cedears+= largo * 0.15;
        }
      } else {
        if (preocupa === 'inflacion') {
          w.cer      += largo * 0.35;
          w.lecaps   += largo * 0.20;
          w.acciones += largo * 0.20;
          w.fci_infl += largo * 0.25;
        } else if (preocupa === 'cambio') {
          w.cedears  += largo * 0.30;
          w.on       += largo * 0.25;
          w.acciones += largo * 0.20;
          w.cer      += largo * 0.15;
          w.fci_mm   += largo * 0.10;
        } else {
          w.cer      += largo * 0.25;
          w.acciones += largo * 0.20;
          w.cedears  += largo * 0.20;
          w.on       += largo * 0.15;
          w.fci_mm   += largo * 0.20;
        }
      }
    } else if (!dolarLP) {
      // Agresivo
      if (bajFrecuencia) {
        // Revisión mensual/rara: sin acciones, CEDEARs solo complemento, prioridad ONs + FCI
        if (preocupa === 'inflacion') {
          w.cer      += largo * 0.40;
          w.fci_infl += largo * 0.30;
          w.lecaps   += largo * 0.20;
          w.cedears  += largo * 0.10;
        } else if (preocupa === 'cambio') {
          w.on        += largo * 0.40;
          w.fci_mm    += largo * 0.25;
          w.cedears   += largo * 0.15;
          w.soberanos += largo * 0.20;
        } else {
          w.on        += largo * 0.35;
          w.fci_mm    += largo * 0.25;
          w.cedears   += largo * 0.15;
          w.cer       += largo * 0.15;
          w.soberanos += largo * 0.10;
        }
      } else {
        if (preocupa === 'inflacion') {
          w.cer      += largo * 0.30;
          w.acciones += largo * 0.30;
          w.cedears  += largo * 0.20;
          w.fci_infl += largo * 0.20;
        } else if (preocupa === 'cambio') {
          w.cedears   += largo * 0.30;
          w.on        += largo * 0.25;
          w.soberanos += largo * 0.25;
          w.acciones  += largo * 0.15;
          w.cer       += largo * 0.05;
        } else {
          w.acciones  += largo * 0.25;
          w.cedears   += largo * 0.20;
          w.soberanos += largo * 0.20;
          w.on        += largo * 0.20;
          w.cer       += largo * 0.15;
        }
      }
    }
  }

  // ── AJUSTE MENOR POR MONEDA (ya está en la lógica base, aquí solo fino) ──
  if (moneda === 'dolares') { w.cedears += 5; w.on += 5; }
  else if (moneda === 'pesos') { w.cer += 5; w.lecaps += 5; }
  else { w.cedears += 3; w.on += 3; }

  // ── CARRY TRADE ──
  if (carryOK) w.soberanos += 10;

  // ── APLICAR EXCLUSIONES — redistribuir ──
  if (!rvOK) {
    const rv = w.acciones + w.cedears; w.acciones=0; w.cedears=0;
    if (onOK)                                          { w.on  += Math.round(rv * 0.6); w.fci_mm += Math.round(rv * 0.4); }
    else if (moneda === 'dolares' || moneda === 'mixto'){ w.fci_mm += rv; }
    else                                               { w.cer += Math.round(rv * 0.55); w.lecaps += Math.round(rv * 0.45); }
  } else if (!accOK && w.acciones > 0) {
    // Revisión mensual/rara: redistribuir acciones a ONs + FCI
    const av = w.acciones; w.acciones = 0;
    if (onOK) { w.on += Math.round(av * 0.6); w.fci_mm += Math.round(av * 0.4); }
    else      { w.fci_mm += Math.round(av * 0.5); w.cer += Math.round(av * 0.5); }
  }
  // Regla cupón mínimo: si monto asignado a ONs < USD 1.667, el cupón (~6%) sería < $100 — no conviene
  const montoON = usd * (w.on / 100);
  if (onOK && montoON < 1667) {
    const ow = w.on; w.on = 0;
    w.fci_mm += ow;
  }
  if (!onOK) {
    const ow = w.on; w.on = 0;
    // Redistribuir según preocupación y moneda — nunca a CER/LECAPs si el cliente valúa en USD
    const esDolarizado = (moneda === 'dolares' || moneda === 'mixto');
    const soloCambio   = (preocupa === 'cambio' || (preocupa === 'ambas' && esDolarizado));
    if (esDolarizado && soloCambio) {
      w.fci_mm += ow;
    } else if (esDolarizado) {
      if (rvOK) { w.cedears += Math.round(ow * 0.5); w.fci_mm += Math.round(ow * 0.5); }
      else      { w.fci_mm += ow; }
    } else {
      // Pesos / inflación: CER + LECAPs
      w.cer    += Math.round(ow * 0.55);
      w.lecaps += Math.round(ow * 0.45);
    }
  }
  if (!sbOK) {
    const sw = w.soberanos; w.soberanos=0;
    if (rvOK) { w.cedears += Math.round(sw * 0.6); w.on += onOK ? Math.round(sw * 0.4) : 0; w.lecaps += onOK ? 0 : Math.round(sw * 0.4); }
    else      { w.cer += Math.round(sw * 0.55); w.lecaps += Math.round(sw * 0.45); }
  }

  // FCI mínimo para capital muy bajo
  if (usd < 500 && w.fci_mm < 15) {
    const ex = 15 - w.fci_mm; w.fci_mm += ex;
    const tk = Object.keys(w).filter(k=>k!=='fci_mm').sort((a,b)=>w[b]-w[a])[0];
    w[tk] = Math.max(0, w[tk] - ex);
  }

  // ── NORMALIZAR — preservando exactamente el tramo líquido en fci_mm ──
  const liquidExact = liq;
  // Guardar y remover fci_mm y fci_usd del pool a normalizar
  const fci_mm_raw  = w.fci_mm;  w.fci_mm  = 0;
  const fci_usd_raw = w.fci_usd; w.fci_usd = 0;
  let tot = Object.values(w).reduce((a,b)=>a+b, 0);
  // El espacio disponible para el resto es 100 - líquido - fci_usd ya asignado
  const usedFixed = liquidExact + fci_usd_raw;
  const remaining  = 100 - usedFixed;
  if (tot === 0) { w.lecaps = remaining; tot = remaining; }
  // Normalizar el resto
  Object.keys(w).forEach(k => w[k] = Math.round(w[k]/tot*remaining));
  let diff = remaining - Object.values(w).reduce((a,b)=>a+b, 0);
  const tk = Object.keys(w).filter(k=>k!=='fci_mm'&&k!=='fci_usd').sort((a,b)=>w[b]-w[a])[0];
  if (tk) w[tk] += diff;
  // Restaurar valores fijos
  w.fci_mm  = liquidExact;
  w.fci_usd = fci_usd_raw;

  const sorted = Object.entries(w).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);
  return {alloc:sorted, rvOK, onOK, sbOK, carryOK};
}

